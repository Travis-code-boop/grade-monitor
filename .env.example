RUC_USERNAME=replace_with_student_or_staff_id
RUC_PASSWORD=replace_with_vruc_password
PUSHPLUS_TOKEN=replace_with_pushplus_token
GRADE_HASH_SALT=replace_with_random_secret

# Optional legacy fallback. Leave empty when using RUC_USERNAME/RUC_PASSWORD.
RUC_TOKEN=
RUC_COOKIE=

# Optional. The unified login prefixes plain student/staff IDs as "ruc:<id>".
RUC_LOGIN_SCHOOL_CODE=ruc

# Optional filters. Leave empty to query all semesters visible to the account.
RUC_SEMESTERS=
RUC_PAGE_SIZE=100
RUC_PLAN_TYPE=1
RUC_BROWSER_USER_AGENT=
STATE_FILE=seen_grades.json
